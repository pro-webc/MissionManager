# Supabase PostgreSQL
# DATABASE_URL: プール接続（Supabase Transaction Pooler / Serverless 用、ポート 6543）
# DIRECT_URL: 直接接続（マイグレーション用、ポート 5432）
# Supabase ダッシュボード > Settings > Database から取得してください
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Auth.js（メール・パスワード認証）
# npx auth secret で生成、または openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# 本番（Vercel 等）では DATABASE_URL と DIRECT_URL の両方を必ず設定すること。
# npm run build 内で prisma migrate deploy が走り、本番 DB にスキーマが適用されます。
