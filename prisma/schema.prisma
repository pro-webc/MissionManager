generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String       @map("password_hash")
  name         String?
  createdAt    DateTime     @default(now())
  departments  Department[]
  projects     Project[]
  assignees    Assignee[]
}

model Department {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String      @map("department_id")
  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  assigneeId   String?     @map("assignee_id")
  assignee     Assignee?   @relation("ProjectAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  name         String
  summary      String?
  dueDate      DateTime?   @map("due_date") @db.Date
  order        Int         @default(0)
  createdAt    DateTime    @default(now())
  mainTasks    MainTask[]

  @@map("Genre")
}

model Assignee {
  id        String     @id @default(uuid())
  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime   @default(now())
  projects  Project[]  @relation("ProjectAssignee")
  mainTasks MainTask[]
}

model MainTask {
  id          String    @id @default(uuid())
  projectId   String    @map("genre_id")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?   @map("assignee_id")
  assignee    Assignee? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  name        String
  summary     String?
  dueDate     DateTime? @map("due_date") @db.Date
  completedAt DateTime? @map("completed_at")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  subTasks    SubTask[]

  @@map("Mission")
}

model SubTask {
  id          String    @id @default(uuid())
  mainTaskId  String    @map("mission_id")
  mainTask    MainTask  @relation(fields: [mainTaskId], references: [id], onDelete: Cascade)
  name        String
  summary     String?
  done        Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  dueDate     DateTime? @map("due_date") @db.Date
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@map("Task")
}
